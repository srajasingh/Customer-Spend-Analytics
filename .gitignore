# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Project artefacts
# Keep small generated outputs in git so the README screenshots and CSVs work,
# but ignore the heavy SQLite db (regenerable via the ETL).
db/*.db
db/*.sqlite

# Raw data: too large for GitHub free tier (66 MB triggers the 50 MB warning).
# Users download it from Kaggle - see README "Quick start".
data/*.csv
!data/.gitkeep

# Logs / temp
*.log
.tmp/
